{
  "name": "@jafps/config",
  "version": "1.2.1",
  "description": "Functions for reading configuration.",
  "type": "module",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "tsc",
    "test": "node --enable-source-maps --experimental-test-coverage --test-coverage-exclude \"src/**/__tests__/*.ts\" --test \"./dist/**/__tests__/*.{spec,test}.js\"",
    "lint": "eslint"
  },
  "author": "Joshua Avalon",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jafpsjs/config.git"
  },
  "bugs": {
    "url": "https://github.com/jafpsjs/config/issues"
  },
  "homepage": "https://github.com/jafpsjs/config#readme",
  "imports": {
    "#base": {
      "import": "./dist/base/index.js"
    },
    "#env": {
      "import": "./dist/env/index.js"
    },
    "#json": {
      "import": "./dist/json/index.js"
    },
    "#util": {
      "import": "./dist/util/index.js"
    },
    "#yaml": {
      "import": "./dist/yaml/index.js"
    }
  },
  "exports": {
    ".": {
      "import": "./dist/index.js"
    },
    "./base": {
      "import": "./dist/base/index.js"
    },
    "./env": {
      "import": "./dist/env/index.js"
    },
    "./json": {
      "import": "./dist/json/index.js"
    },
    "./yaml": {
      "import": "./dist/yaml/index.js"
    }
  },
  "keywords": [
    "fastify"
  ],
  "files": [
    "dist/**/*",
    "!dist/**/__tests__/**/*"
  ],
  "devDependencies": {
    "@joshuaavalon/eslint-config-javascript": "^11.0.3",
    "@joshuaavalon/eslint-config-typescript": "^11.0.0",
    "@types/node": "^25.3.3",
    "eslint": "^10.0.2",
    "fastify": "^5.7.4",
    "globals": "^17.4.0",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "mergician": "^2.0.2",
    "ts-extras": "0.17.0",
    "type-fest": "^5.4.4",
    "typebox": "^1.1.5",
    "yaml": "^2.8.2"
  }
}
